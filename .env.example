# ---- Landing pages /lp (Google Ads) ----

# Cal.com inline embed. Sin esto, las landings muestran el calendario placeholder.
# Formato: "usuario/event-type" (lo que va después de cal.com/).
VITE_CALCOM_LINK=djpartners/diagnostico

# (Opcional) Conversión directa de Google Ads por landing, formato "AW-XXXXXXXXX/label".
# Si usas GTM, deja esto vacío y dispara la conversión con el evento `generate_lead`.
VITE_ADS_CONVERSION_CUADRO=
VITE_ADS_CONVERSION_AUTO=
